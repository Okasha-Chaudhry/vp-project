@page "/video-call/{SessionId:guid}"
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@implements IAsyncDisposable
@inject ISessionService SessionService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(session == null ? "Video Call - StudyConnect" : $"{session.Title} - Video Call")</PageTitle>

<div class="video-shell">
    @if (isLoading)
    {
        <div class="video-state">
            <div class="spinner"></div>
            <span>Preparing video room...</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="video-state">
            <i class="bi bi-exclamation-circle-fill danger"></i>
            <h1>Video Call Unavailable</h1>
            <p>@errorMessage</p>
            <button class="btn btn-primary" @onclick="BackToSessions">
                <i class="bi bi-arrow-left"></i>
                Back to Sessions
            </button>
        </div>
    }
    else if (session != null && !session.UseBuiltInVideoCall)
    {
        <div class="video-state">
            <i class="bi bi-box-arrow-up-right"></i>
            <h1>External Meeting</h1>
            <p>This session uses an external meeting link.</p>
            <div class="video-actions">
                @if (!string.IsNullOrEmpty(session.MeetingLink))
                {
                    <button class="btn btn-primary" @onclick="OpenExternalMeeting">
                        <i class="bi bi-camera-video-fill"></i>
                        Open Meeting
                    </button>
                }
                <button class="btn btn-secondary" @onclick="BackToSessions">
                    Back to Sessions
                </button>
            </div>
        </div>
    }
    else if (session != null && !CanJoin)
    {
        <div class="video-state">
            <i class="bi bi-clock-history"></i>
            <h1>@GetWaitingTitle()</h1>
            <p>@session.Title</p>
            <div class="session-time">@GetWaitingMessage()</div>
            <button class="btn btn-secondary" @onclick="BackToSessions">
                Back to Sessions
            </button>
        </div>
    }
    else if (session != null)
    {
        <header class="video-topbar">
            <div>
                <h1>@session.Title</h1>
                <p>@FormatLocalDateTime(session.ScheduledAt) &middot; @session.DurationMinutes minutes</p>
            </div>
            <button class="leave-button" @onclick="LeaveCall" title="Leave call">
                <i class="bi bi-telephone-x-fill"></i>
                Leave
            </button>
        </header>

        @if (!string.IsNullOrEmpty(connectionMessage))
        {
            <div class="video-banner">
                <i class="bi bi-info-circle"></i>
                @connectionMessage
            </div>
        }

        <div id="studyconnect-jitsi" class="video-frame"></div>
    }
</div>

@code {
    [Parameter] public Guid SessionId { get; set; }

    private SessionDto? session;
    private bool isLoading = true;
    private bool hasStartedVideo;
    private string? errorMessage;
    private string? connectionMessage;
    private string displayName = "StudyConnect User";
    private string email = "";

    private bool CanJoin
    {
        get
        {
            if (session == null) return false;
            var now = DateTime.UtcNow;
            var starts = ToUtcDateTime(session.ScheduledAt).AddMinutes(-15);
            var ends = ToUtcDateTime(session.ScheduledAt).AddMinutes(session.DurationMinutes);
            return now >= starts && now <= ends;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            displayName = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? displayName;
            email = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";

            session = await SessionService.GetSessionByIdAsync(SessionId);
            if (session == null)
            {
                errorMessage = "The session does not exist, or you are not a member of its group.";
            }
            else if (string.IsNullOrWhiteSpace(session.RoomName) && session.UseBuiltInVideoCall)
            {
                errorMessage = "This session does not have a video room. Create a new session and enable built-in video.";
            }
        }
        catch
        {
            errorMessage = "Could not load the session. Please check that the API is running and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!hasStartedVideo && !isLoading && errorMessage == null && session?.UseBuiltInVideoCall == true && CanJoin)
        {
            hasStartedVideo = true;
            await StartVideoCall();
        }
    }

    private async Task StartVideoCall()
    {
        try
        {
            connectionMessage = "Connecting to the video room...";
            StateHasChanged();

            await JSRuntime.InvokeVoidAsync("studyConnectVideo.start", new
            {
                domain = "meet.jit.si",
                containerId = "studyconnect-jitsi",
                roomName = session!.RoomName,
                displayName,
                email
            });

            connectionMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not start the video room: {ex.Message}";
            connectionMessage = null;
            StateHasChanged();
        }
    }

    private string GetWaitingTitle()
    {
        if (session == null) return "Session Unavailable";
        return DateTime.UtcNow < ToUtcDateTime(session.ScheduledAt).AddMinutes(-15)
            ? "Session Not Ready Yet"
            : "Session Has Ended";
    }

    private string GetWaitingMessage()
    {
        if (session == null) return "";

        var joinTime = ToLocalDateTime(session.ScheduledAt).AddMinutes(-15);
        var endTime = ToLocalDateTime(session.ScheduledAt).AddMinutes(session.DurationMinutes);

        if (DateTime.Now < joinTime)
        {
            return $"Video opens at {joinTime:g}.";
        }

        return $"This session ended at {endTime:g}.";
    }

    private async Task OpenExternalMeeting()
    {
        if (!string.IsNullOrEmpty(session?.MeetingLink))
        {
            await JSRuntime.InvokeVoidAsync("open", session.MeetingLink, "_blank");
        }
    }

    private async Task LeaveCall()
    {
        await JSRuntime.InvokeVoidAsync("studyConnectVideo.stop");
        BackToSessions();
    }

    private void BackToSessions()
    {
        NavigationManager.NavigateTo("/sessions");
    }

    private static DateTime ToUtcDateTime(DateTime dateTime)
        => dateTime.Kind == DateTimeKind.Unspecified
            ? DateTime.SpecifyKind(dateTime, DateTimeKind.Utc)
            : dateTime.ToUniversalTime();

    private static DateTime ToLocalDateTime(DateTime dateTime)
        => ToUtcDateTime(dateTime).ToLocalTime();

    private static string FormatLocalDateTime(DateTime dateTime)
        => ToLocalDateTime(dateTime).ToString("MMM dd, yyyy h:mm tt");

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("studyConnectVideo.stop");
        }
        catch
        {
            // The JS runtime may already be gone during navigation.
        }
    }
}

<style>
.video-shell {
    height: 100vh;
    min-height: 560px;
    background: #050816;
    color: #fff;
    display: flex;
    flex-direction: column;
}

.video-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 24px;
    text-align: center;
}

.video-state i {
    font-size: 3.5rem;
    color: #14b8a6;
}

.video-state i.danger {
    color: #ef4444;
}

.video-state h1 {
    margin: 0;
    font-size: 1.6rem;
}

.video-state p {
    max-width: 520px;
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
}

.session-time {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 10px 14px;
}

.video-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
}

.video-topbar {
    height: 74px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 18px;
    background: rgba(0, 0, 0, 0.62);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
}

.video-topbar h1 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
}

.video-topbar p {
    margin: 4px 0 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.78rem;
}

.leave-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(239, 68, 68, 0.42);
    background: rgba(239, 68, 68, 0.16);
    color: #fff;
    border-radius: 8px;
    padding: 9px 13px;
    font-weight: 700;
}

.leave-button:hover {
    background: rgba(239, 68, 68, 0.28);
}

.video-banner {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: rgba(37, 99, 235, 0.24);
    color: #dbeafe;
    font-size: 0.86rem;
}

.video-frame {
    flex: 1;
    min-height: 0;
    background: #000;
}
</style>
