@page "/"
@attribute [Authorize]
@inject IGroupService GroupService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard — StudyConnect</PageTitle>

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Overview of your study groups and activity</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-secondary" @onclick="ShowJoinModal">
            <i class="bi bi-box-arrow-in-right"></i>
            Join Group
        </button>
        <button class="btn btn-primary" @onclick="ShowCreateModal">
            <i class="bi bi-plus-lg"></i>
            New Group
        </button>
    </div>
</div>

@if (isLoading)
{
    <!-- Skeleton Stats -->
    <div class="row g-4 mb-4">
        @for (int i = 0; i < 4; i++)
        {
            <div class="col-md-6 col-lg-3" style="padding:8px;">
                <div class="skeleton-card">
                    <div class="skeleton" style="width:44px;height:44px;border-radius:8px;margin-bottom:14px;"></div>
                    <div class="skeleton" style="width:60%;height:28px;margin-bottom:8px;"></div>
                    <div class="skeleton" style="width:40%;height:14px;"></div>
                </div>
            </div>
        }
    </div>
    <!-- Skeleton Cards -->
    <div class="row g-4">
        @for (int i = 0; i < 3; i++)
        {
            <div class="col-md-6 col-lg-4" style="padding:8px;">
                <div class="skeleton-card" style="height:180px;">
                    <div class="skeleton" style="width:48px;height:48px;border-radius:8px;margin-bottom:14px;"></div>
                    <div class="skeleton" style="width:70%;height:18px;margin-bottom:8px;"></div>
                    <div class="skeleton" style="width:90%;height:14px;margin-bottom:6px;"></div>
                    <div class="skeleton" style="width:60%;height:14px;"></div>
                </div>
            </div>
        }
    </div>
}
else
{
    <!-- Stats Row -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:16px; margin-bottom:28px;">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
            <div class="stat-value">@groups.Count</div>
            <div class="stat-label">Study Groups</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon teal"><i class="bi bi-calendar-event-fill"></i></div>
            <div class="stat-value">@groups.Sum(g => g.SessionCount)</div>
            <div class="stat-label">Total Sessions</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon yellow"><i class="bi bi-check2-square"></i></div>
            <div class="stat-value">@groups.Sum(g => g.TaskCount)</div>
            <div class="stat-label">Assigned Tasks</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-folder2-open"></i></div>
            <div class="stat-value">@groups.Sum(g => g.ResourceCount)</div>
            <div class="stat-label">Shared Resources</div>
        </div>
    </div>

    @if (groups.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-people"></i></div>
            <h4>No Study Groups Yet</h4>
            <p>Create a new study group or join one with an invite code to start collaborating.</p>
            <div class="empty-state-actions">
                <button class="btn btn-primary" @onclick="ShowCreateModal">
                    <i class="bi bi-plus-lg"></i> Create Group
                </button>
                <button class="btn btn-secondary" @onclick="ShowJoinModal">
                    <i class="bi bi-box-arrow-in-right"></i> Join with Code
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="section-title">Your Groups</div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px;">
            @{int idx = 0;}
            @foreach (var group in groups)
            {
                int colorIdx = idx % 6;
                idx++;
                <div class="group-card" @onclick="() => NavigateToGroup(group.Id)">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                        <div class="group-icon variant-@colorIdx">
                            <i class="bi bi-book-fill"></i>
                        </div>
                        <span class="group-role-badge @(group.UserRole == "Admin" ? "admin" : "member")">
                            <i class="bi bi-@(group.UserRole == "Admin" ? "shield-check" : "person")"></i>
                            @group.UserRole
                        </span>
                    </div>
                    <h5>@group.Name</h5>
                    <p>@(string.IsNullOrEmpty(group.Description) ? "No description provided." : group.Description)</p>
                    <div class="group-meta">
                        <span><i class="bi bi-people"></i> @group.MemberCount @(group.MemberCount == 1 ? "member" : "members")</span>
                        <span><i class="bi bi-calendar-event"></i> @group.SessionCount sessions</span>
                        <span><i class="bi bi-check2-square"></i> @group.TaskCount tasks</span>
                        <span><i class="bi bi-folder2"></i> @group.ResourceCount resources</span>
                    </div>
                    @if (group.CreatedBy != null)
                    {
                        <div style="margin-top:12px; padding-top:12px; border-top:1px solid var(--border);">
                            <span class="fs-xs text-muted">Created by @group.CreatedBy.Name</span>
                        </div>
                    }
                </div>
            }
        </div>
    }
}

<!-- Error Message -->
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">
        <i class="bi bi-exclamation-circle-fill"></i>
        @errorMessage
    </div>
}

<!-- Create Modal -->
@if (showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h5><i class="bi bi-plus-circle me-2" style="color:var(--primary);"></i>Create Study Group</h5>
                <button class="modal-close-btn" @onclick="CloseModals"><i class="bi bi-x-lg"></i></button>
            </div>
            <EditForm Model="createRequest" OnValidSubmit="HandleCreateSubmit">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Group Name <span class="required-star">*</span></label>
                        <InputText @bind-Value="createRequest.Name" class="form-control"
                                   placeholder="e.g., Advanced Calculus Study Group" />
                        <ValidationMessage For="@(() => createRequest.Name)" class="validation-message" />
                    </div>
                    <div class="form-group mb-0">
                        <label class="form-label">Description</label>
                        <InputTextArea @bind-Value="createRequest.Description" class="form-control" rows="3"
                                       placeholder="What topics will this group cover?" />
                        <ValidationMessage For="@(() => createRequest.Description)" class="validation-message" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting) { <span class="spinner spinner-sm"></span> }
                        Create Group
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Join Modal -->
@if (showJoinModal)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h5><i class="bi bi-box-arrow-in-right me-2" style="color:var(--accent);"></i>Join Study Group</h5>
                <button class="modal-close-btn" @onclick="CloseModals"><i class="bi bi-x-lg"></i></button>
            </div>
            <EditForm Model="joinRequest" OnValidSubmit="HandleJoinSubmit">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-group mb-0">
                        <label class="form-label">Invite Code <span class="required-star">*</span></label>
                        <InputText @bind-Value="joinRequest.InviteCode" class="form-control"
                                   placeholder="8-character code (e.g., ABC12345)" maxlength="8"
                                   style="text-transform:uppercase; letter-spacing:0.2em; font-family:monospace; font-size:1rem;" />
                        <ValidationMessage For="@(() => joinRequest.InviteCode)" class="validation-message" />
                        <span class="form-text">Ask the group admin for their invite code.</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting) { <span class="spinner spinner-sm"></span> }
                        Join Group
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<StudyGroupDto> groups = new();
    private bool isLoading = true;
    private bool showCreateModal = false;
    private bool showJoinModal = false;
    private bool isSubmitting = false;
    private string? errorMessage;
    private CreateGroupRequest createRequest = new();
    private JoinGroupRequest joinRequest = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadGroups();
    }

    private async Task LoadGroups()
    {
        isLoading = true;
        errorMessage = null;
        groups = await GroupService.GetMyGroupsAsync();
        isLoading = false;
    }

    private void NavigateToGroup(Guid groupId)
        => NavigationManager.NavigateTo($"/groups/{groupId}");

    private void ShowCreateModal() { createRequest = new(); showCreateModal = true; showJoinModal = false; errorMessage = null; }
    private void ShowJoinModal() { joinRequest = new(); showJoinModal = true; showCreateModal = false; errorMessage = null; }
    private void CloseModals() { showCreateModal = false; showJoinModal = false; }

    private async Task HandleCreateSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        var group = await GroupService.CreateGroupAsync(createRequest);
        if (group != null) { CloseModals(); await LoadGroups(); }
        else errorMessage = "Failed to create group. Please try again.";
        isSubmitting = false;
    }

    private async Task HandleJoinSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        var group = await GroupService.JoinGroupAsync(joinRequest);
        if (group != null) { CloseModals(); await LoadGroups(); }
        else errorMessage = "Invalid invite code or you're already a member.";
        isSubmitting = false;
    }
}
